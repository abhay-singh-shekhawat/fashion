# ============================================
# SOCKET.IO CONFIGURATION
# ============================================

# Port number for the server
# DEFAULT: 5000
# WHAT: The port your Express/Socket.IO server listens on
# EXAMPLE: PORT=5000 (access at http://localhost:5000)
PORT=5000

# Environment: development, production, or test
# DEFAULT: development
# WHAT: Determines logging level, error handling, and performance settings
# PRODUCTION: Less logging, optimized performance, minified errors
# DEVELOPMENT: More logging, detailed errors, auto-reload
NODE_ENV=development

# Socket.IO CORS Origin
# DEFAULT: http://localhost:3000
# WHAT: Which frontend URL(s) can connect to your WebSocket
# 
# DEVELOPMENT (single frontend):
#   SOCKET_CORS_ORIGIN=http://localhost:3000
# 
# PRODUCTION (multiple URLs):
#   SOCKET_CORS_ORIGIN=https://fashionapp.com,https://app.fashionapp.com
# 
# REACT NATIVE (mobile app):
#   SOCKET_CORS_ORIGIN=*
#   (You might want to be more specific with IP/domain)
#
# WHY CORS: Security - prevents other websites from connecting to your socket
SOCKET_CORS_ORIGIN=http://localhost:3000

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB connection string
# WHAT: URL to connect to your MongoDB database
# FORMAT: mongodb+srv://username:password@cluster.mongodb.net/databaseName?options
MONGODB_URI=mongodb://localhost:27017/fashion

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret key for signing tokens
# WHAT: Secret string used to sign and verify JWT tokens
# SECURITY: Keep this STRONG and SECRET
# GENERATE: Use: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============================================
# REDIS CONFIGURATION (for caching & sessions)
# ============================================

# Redis server URL
# WHAT: Connection string to Redis server
# LOCAL: redis://localhost:6379
# CLOUD: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================
# EXTERNAL SERVICES
# ============================================

# Cloudinary configuration (image upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenAI/Groq API keys (for AI features)
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key

# Weather API
WEATHER_API_KEY=your_weather_api_key

# ============================================
# SOCKET.IO EXPLANATION
# ============================================
#
# WHAT IS SOCKET.IO?
# - Library for real-time, bi-directional communication
# - Client (Frontend) ←→ Server (Backend)
# - Used instead of HTTP requests for live updates
#
# HOW DOES IT WORK?
# 1. Client connects via WebSocket (or polling fallback)
# 2. Server stores client's socket ID
# 3. Server can now send events instantly to client
# 4. Client can also send events to server
#
# EXAMPLE:
# Server: io.to(`user:123`).emit("scan:complete", { score: 85 })
# Client receives instantly: socket.on("scan:complete", (data) => { ... })
#
# CORS SECURITY:
# - Only allow specific frontend URLs to connect
# - Prevents malicious websites from connecting to your server
# - Set SOCKET_CORS_ORIGIN to your frontend domain(s)
#
# ============================================
